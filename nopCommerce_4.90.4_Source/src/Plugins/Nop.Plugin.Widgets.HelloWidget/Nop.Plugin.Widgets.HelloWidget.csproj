<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>  
    <Copyright>Copyright © Khraisheh</Copyright>
    <Company>Jordan Tech Store</Company>
    <Authors>Shahad Khraisheh</Authors>
    <Version>1.0.0</Version>
    <Description>Injects a custom tech store greeting on the homepage.</Description>
    <OutputPath>..\..\Presentation\Nop.Web\Plugins\Widgets.HelloWidget</OutputPath>
    <OutDir>$(OutputPath)</OutDir>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Presentation\Nop.Web.Framework\Nop.Web.Framework.csproj" />
  </ItemGroup>
<ItemGroup>
    <None Update="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Views\**\*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>  
  <ItemGroup>
    <Folder Include="Views\" />
  </ItemGroup>

</Project>
