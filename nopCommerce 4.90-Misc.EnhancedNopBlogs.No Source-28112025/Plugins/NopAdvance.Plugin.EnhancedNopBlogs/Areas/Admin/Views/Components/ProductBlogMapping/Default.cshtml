@model EnhancedBlogPostModel

@{
    var customer = await workContext.GetCurrentCustomerAsync();
    const string hideProductMappingBlockAttributeName = "BlogPostPage.HideProductMappingBlock";
    var hideProductMappingBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideProductMappingBlockAttributeName);
}

<nop-cards id="product-cards">
    <nop-card asp-name="blog-post-product" asp-icon="fas fa-th-list" asp-title="@T(LocaleResourceDefaults.BLOG_POST_PANEL_TITLE_PRODUCT).Text" asp-hide-block-attribute-name="@hideProductMappingBlockAttributeName" asp-hide="@hideProductMappingBlock" asp-advanced="true">
        <div class="card-body">
            @if (Model.ProductId > 0)
            {
                <div class="card card-default">
                    <div class="card-body">

                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                            Name = "blog-products-grid",
                                        UrlRead = new DataUrl("ProductList", "NopAdvanceEnhancedNopBlogs", new RouteValueDictionary { [nameof(Model.BlogPostProductSearchModel.ProductId)] = Model.ProductId }),
                                        UrlDelete = new DataUrl("ProductDelete", "NopAdvanceEnhancedNopBlogs", null),
                                        UrlUpdate = new DataUrl("ProductUpdate", "NopAdvanceEnhancedNopBlogs", null),
                                        Length = Model.BlogPostProductSearchModel.PageSize,
                                        LengthMenu = Model.BlogPostProductSearchModel.AvailablePageSizes,
                                        ColumnCollection = new List<ColumnProperty>
                                        {
                                        new ColumnProperty(nameof(BlogPostProductMappingModel.BlogName))
                                        {
                                        Title = T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.EnhancedNopBlogMapping.GridFields.BlogTitle").Text
                                        },
                                        new ColumnProperty(nameof(BlogPostProductMappingModel.DisplayOrder))
                                        {
                                        Title = T("Admin.Catalog.Categories.Products.Fields.DisplayOrder").Text,
                                        Width = "150",
                                        ClassName = NopColumnClassDefaults.CenterAll,
                                        Editable = true,
                                        EditType = EditType.Number
                                        },
                                        new ColumnProperty(nameof(BlogPostProductMappingModel.BlogId))
                                        {
                                        Title = T("Admin.Common.View").Text,
                                        Width = "150",
                                        ClassName = NopColumnClassDefaults.Button,
                                        Render = new RenderButtonView(new DataUrl("~/Admin/Blog/BlogPostEdit/", nameof(BlogPostProductMappingModel.BlogId)))
                                        },
                                        new ColumnProperty(nameof(BlogPostProductMappingModel.Id))
                                        {
                                        Title = T("Admin.Common.Edit").Text,
                                        Width = "200",
                                        ClassName =  NopColumnClassDefaults.Button,
                                        Render = new RenderButtonsInlineEdit()
                                        },
                                        new ColumnProperty(nameof(BlogPostProductMappingModel.Id))
                                        {
                                        Title = T("Admin.Common.Delete").Text,
                                        Width = "100",
                                        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                                        ClassName = NopColumnClassDefaults.Button
                                        }
                                        }
                                        })
                </div>
            </div>

            <div class="card-footer">
                <button type="submit" id="btnAddNewProduct"
                        onclick="javascript:OpenWindow('@(Url.Action("ProductBlogAddPopup", "NopAdvanceEnhancedNopBlogs", new { productId = Model.ProductId, btnId = "btnRefreshBlogPostProducts" }))', 800, 800, true); return false;"
                        class="btn btn-primary">
                    @T(LocaleResourceDefaults.BLOG_POST_PRODUCT_MODEL_TITLE_ADDNEW)
                </button>
                <button type="submit" id="btnRefreshBlogPostProducts" style="display: none"></button>
                <script>
                    $(document).ready(function () {
                        $('#btnRefreshBlogPostProducts').click(function () {
                            //refresh grid
                            updateTable('#blog-products-grid');

                            //return false to don't reload a page
                            return false;
                        });
                    });
                </script>
            </div>
                        }
        </div>

    </nop-card>
</nop-cards>