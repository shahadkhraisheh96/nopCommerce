@model OverrideBlogPostModel

@{
    const string hideInfoBlockAttributeName = "BlogPostPage.HideInfoBlock";
    var customer = await workContext.GetCurrentCustomerAsync();
    var hideInfoBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideInfoBlockAttributeName);

    const string hideTokenBlockAttributeName = "BlogPostPage.HideTokenBlock";
    var hideTokenBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideTokenBlockAttributeName, defaultValue: true);

    const string hideSeoBlockAttributeName = "BlogPostPage.HideSEOBlock";
    var hideSeoBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideSeoBlockAttributeName, defaultValue: true);
}

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden" />

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <nop-cards id="blog-post-cards">
                <nop-card asp-name="blog-post-info" asp-icon="fas fa-info" asp-title="@T("Admin.ContentManagement.Blog.BlogPosts.Info")" asp-hide-block-attribute-name="@hideInfoBlockAttributeName" asp-hide="@hideInfoBlock" asp-advanced="false">@await Html.PartialAsync("~/Plugins/NopAdvance.Plugin.EnhancedNopBlogs/Areas/Admin/Views/Blog/_CreateOrUpdate.Info.cshtml", Model)</nop-card>
                @if(nopAdvanceEnhancedNopBlogsSettings.Enabled)
                {
                 <nop-card asp-name="blog-post-token" asp-icon="fas fa-coins" asp-title="@T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.Tokens.Title")" asp-hide-block-attribute-name="@hideTokenBlockAttributeName" asp-hide="@hideTokenBlock" asp-advanced="false">
                    <div class="card-body">
                        <div class="card card-default">
                            <div class="card-header">
                                <strong>@T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.Tokens.ProductTokens")</strong>
                            </div>
                            <div class="card-body">
                                <div class="callout bg-gray-light no-margin mb-3">
                                    @T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.Tokens.ProductTokens.Note")
                                </div>
                                 <div class="callout bg-gray-light no-margin mb-3">
                                     @T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.Tokens.ProductTokens.Note2")
                                 </div>
                                 <div class="callout bg-gray-light no-margin mb-3">
                                    @T("NopAdvance.Plugin.EnhancedNopBlogs.Admin.Tokens.ProductTokens.Note3")
                                 </div>
                            </div>
                        </div>
                    </div>
                </nop-card>
                }
                <nop-card asp-name="blog-post-seo" asp-icon="fas fa-search-plus" asp-title="@T("Admin.Common.SEO")" asp-hide-block-attribute-name="@hideSeoBlockAttributeName" asp-hide="@hideSeoBlock" asp-advanced="true">@await Html.PartialAsync("~/Plugins/NopAdvance.Plugin.EnhancedNopBlogs/Areas/Admin/Views/Blog/_CreateOrUpdate.Seo.cshtml", Model)</nop-card>

                @await Component.InvokeAsync(typeof(AdminWidgetViewComponent), new { widgetZone = AdminWidgetZones.BlogPostDetailsBlock, additionalData = Model })
            </nop-cards>
        </div>
    </div>
</section>