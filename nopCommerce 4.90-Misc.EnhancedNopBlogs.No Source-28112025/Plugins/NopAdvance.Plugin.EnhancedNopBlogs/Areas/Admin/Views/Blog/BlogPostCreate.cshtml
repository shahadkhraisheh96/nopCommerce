@model OverrideBlogPostModel

@{    
    Layout = "_AdminLayout";
    //page title
    ViewBag.PageTitle = T("Admin.ContentManagement.Blog.BlogPosts.AddNew").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Blog posts");
}

<form asp-controller="OverrideBlog" asp-action="BlogCreate" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Admin.ContentManagement.Blog.BlogPosts.AddNew")
            @if (nopAdvanceEnhancedNopBlogsSettings.Enabled)
            {
                <small>
                    <i class="fas fa-arrow-circle-left"></i>
                    <a asp-action="BlogPosts">@T("Admin.ContentManagement.Blog.BlogPosts.BackToList")</a>
                </small>
            }
            else
            {
                <small>
                    <i class="fas fa-arrow-circle-left"></i>
                    <a asp-controller="Blog" asp-action="BlogPosts">@T("Admin.ContentManagement.Blog.BlogPosts.BackToList")</a>
                </small>
            }
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.SaveContinue")
            </button>
            @await Component.InvokeAsync(typeof(AdminWidgetViewComponent), new { widgetZone = AdminWidgetZones.BlogDetailsButtons, additionalData = Model })
        </div>
    </div>
    @await Html.PartialAsync("~/Plugins/NopAdvance.Plugin.EnhancedNopBlogs/Areas/Admin/Views/Blog/_CreateOrUpdate.cshtml", Model)
</form>

