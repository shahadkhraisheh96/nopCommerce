@model AddBlogSearchModel

@{
    Layout = "_AdminPopupLayout";

    //page title
    ViewBag.PageTitle = T(LocaleResourceDefaults.BLOG_WIDGET_BLOGWIDGET_MAPPIN_ADD).Text;

    const string hideSearchBlockAttributeName = "BlogListPopupPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

@if (ViewBag.RefreshPage == true)
{
    <script type="text/javascript">
        try {window.opener.document.forms['@(Context.Request.Query["formId"])'].@(Context.Request.Query["btnId"]).click();}
        catch (e) { }
        window.close();
    </script>
}

<form asp-controller="NopAdvanceEnhancedNopBlogs" asp-action="BlogAddPopup"
      asp-route-blogWidgetId="@Context.Request.Query["blogWidgetId"]"
      asp-route-btnId="@Context.Request.Query["btnId"]"
      asp-route-formId="@Context.Request.Query["formId"]">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T(LocaleResourceDefaults.BLOG_WIDGET_BLOGWIDGET_MAPPIN_ADD)
        </h1>
        <div class="float-right">
            &nbsp;
        </div>
    </div>
    <section class="content">
        <div class="container-fluid">
            <div class="form-horizontal">
                <div class="cards-group">
                    <div class="card card-default card-search card-popup">
                        <div class="card-body"> 
                             
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group row">
                                            <div class="col-sm-5">
                                                <nop-label asp-for="SearchBlogTitle" />
                                            </div>
                                            <div class="col-sm-7">
                                                <nop-editor asp-for="SearchBlogTitle" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-12">
                                        <button type="button" id="search-blogs" class="btn btn-primary btn-search">
                                            <i class="fa fa-search"></i>
                                            @T("Admin.Common.Search")
                                        </button>
                                    </div>
                                </div>
                             
                        </div>
                    </div>
                    <div class="card card-default">
                        <div class="card-body">
                            @await Html.PartialAsync("Table", new DataTablesModel
                       {
                           Name = "blogs-grid",
                           UrlRead = new DataUrl("BlogAddPopupList", "NopAdvanceEnhancedNopBlogs", null),
                           SearchButtonId = "search-blogs",
                           Length = Model.PageSize,
                           LengthMenu = Model.AvailablePageSizes,
                           Filters = new List<FilterParameter>
                           {
                               new FilterParameter(nameof(Model.SearchBlogTitle))
                           },
                           ColumnCollection =  new List<ColumnProperty>
                           {
                               new ColumnProperty(nameof(BlogPostModel.Id))
                               {
                                   IsMasterCheckBox = true,
                                   Render = new RenderCheckBox(nameof(AddBlogModel.SelectedBlogIds)),
                                   ClassName =  NopColumnClassDefaults.CenterAll,
                                   Width = "50"
                               },
                               new ColumnProperty(nameof(BlogPostModel.Title))
                               {
                            Title = T(LocaleResourceDefaults.SEARCH_FIELD_BLOG_TITLE).Text,
                               }
                           }
                       })
                        </div>
                        <div class="card-footer">
                            <button type="submit" name="save" class="btn btn-primary">
                                <i class="far fa-save"></i>
                                @T("Admin.Common.Save")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>