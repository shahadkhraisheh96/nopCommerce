@model BlogPostAttachmentModel

@{

    var themeCssPath = await themeHelper.GetThemeCssPathAsync(PluginDefaults.SYSTEM_NAME);
    var themeJsPath = await themeHelper.GetThemeJsPathAsync(PluginDefaults.SYSTEM_NAME);

    Layout = "";
    NopHtml.AddCssFileParts($"{themeCssPath}/owl.carousel.css");
    NopHtml.AddCssFileParts($"{themeCssPath}/widget.css");
    if ((await workContext.GetWorkingLanguageAsync()).Rtl)
    {
        NopHtml.AddScriptParts(Nop.Web.Framework.UI.ResourceLocation.Footer, $"{themeJsPath}/owl.carousel.min.rtl.js");
        NopHtml.AddCssFileParts($"{themeCssPath}/widget.rtl.css");
    }
    else
    {
        NopHtml.AddScriptParts(Nop.Web.Framework.UI.ResourceLocation.Footer, $"{themeJsPath}/owl.carousel.min.js");
    }
}
@if (Model != null && Model.Download != null)
{
    <div class="enhanced-blog-attachment">
        <label>@T("NopAdvance.Plugin.EnhancedNopBlogs.Public.BlogPost.Title.Attachment")</label>
        <ul>
            <li><a asp-controller="EnhancedNopBlogDownload" asp-action="DownloadAttachment" asp-route-downloadGuid="@Model.Download.DownloadGuid">@($"{Model.Download.Filename}{Model.Download.Extension}")</a></li>
        </ul>
    </div>
}

