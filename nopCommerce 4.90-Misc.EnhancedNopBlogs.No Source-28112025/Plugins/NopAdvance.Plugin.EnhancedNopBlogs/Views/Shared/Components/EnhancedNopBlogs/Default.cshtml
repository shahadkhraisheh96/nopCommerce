@model List<EnhancedNopBlogModel>

@{

    var themeCssPath = await themeHelper.GetThemeCssPathAsync(PluginDefaults.SYSTEM_NAME);
    var themeJsPath = await themeHelper.GetThemeJsPathAsync(PluginDefaults.SYSTEM_NAME);

    Layout = "";
    NopHtml.AddCssFileParts($"{themeCssPath}/owl.carousel.css");
    NopHtml.AddCssFileParts($"{themeCssPath}/widget.css");
    if ((await workContext.GetWorkingLanguageAsync()).Rtl)
    {
        NopHtml.AddScriptParts(Nop.Web.Framework.UI.ResourceLocation.Footer, $"{themeJsPath}/owl.carousel.min.rtl.js");
        NopHtml.AddCssFileParts($"{themeCssPath}/widget.rtl.css");
    }
    else
    {
        NopHtml.AddScriptParts(Nop.Web.Framework.UI.ResourceLocation.Footer, $"{themeJsPath}/owl.carousel.min.js");
    }
    var isMobileDevice = userAgentHelper.IsMobileDevice();
}

<div class="slider enhanced-nop-blog">
    @foreach (var slider in Model)
    {
        if (slider.BlogPostModels.Count() > 0)
        {
            <div class="blog-grid-container @(true ? "" : "not-carousel")">
                <div class="bg-outer-color"></div>
                @if (!string.IsNullOrEmpty(slider.Title))
                {
                    <div class="title">
                        <strong>@slider.Title</strong>
                    </div>
                }
                <div id="@slider.SliderName" class="blog-grid blog-grid-section @(true ? "owl-carousel blog-slider" : "not-carousel")">
                    @foreach (var blog in slider.BlogPostModels)
                    {
                        <div class="post">
                            @foreach (var item in slider.BlogPictureModels)
                            {
                                @if(blog.Id == item.BlogId)
                                {
                                    @if (item.DesktopPictureId > 0 && !isMobileDevice)
                                    {
                                        <a class="blog-overview-picture" href="@Url.RouteUrl("BlogPost", new { SeName = blog.SeName })">
                                            <img src="@item.Link1" alt="@item.AltText1" title="@item.Text1" height="100" width="400" />
                                        </a>
                                    }
                                    else if (isMobileDevice && item.MobilePictureId > 0)
                                    {
                                        <a class="blog-overview-picture" href="@Url.RouteUrl("BlogPost", new { SeName = blog.SeName })">
                                            <img src="@item.Link2" alt="@item.AltText2" title="@item.Text2" height="100" width="400" />
                                        </a>
                                    }
                                    else if (isMobileDevice)
                                    {
                                        <a class="blog-overview-picture" href="@Url.RouteUrl("BlogPost", new { SeName = blog.SeName })">
                                            <img src="@item.Link1" alt="@item.AltText1" title="@item.Text1" height="100" width="400" />
                                        </a>
                                    }
                                }
                            }
                            <div class="post-head">
                                <a class="post-title" href="@Url.RouteUrl("BlogPost", new {SeName = blog.SeName})">@blog.Title</a>
                            </div>
                            <div class="post-body">
                                @Html.Raw(blog.BodyOverview)
                            </div>
                        </div>
                    }
                </div>
            </div>
            <script type="text/javascript" asp-location="Footer">
                $(document).ready(function () {
                    $('#@slider.SliderName').owlCarousel({
                        loop: true,
                        margin: 25,
                        dots: true,
                        nav: false,
                        autoplay: true,
                        autoplayTimeout: 5000,
                        autoplayHoverPause: true,
                        responsive: {
                            0: {
                                items: 1
                            },
                            481: {

                                items: 2
                            },
                            769: {
                                items: 2
                            },
                            1000: {
                                items: 2
                            }
                        }
                    })
                });
            </script>
        }
    }
</div>